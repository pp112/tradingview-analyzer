{
    "columns": [
        "24h_close_change|5",
        "24h_vol_change|5"
    ],
    "filter": [
        {
            "left": "exchange",
            "operation": "in_range",
            "right": [
                "BYBIT"
            ]
        },
        {
            "left": "currency_id",
            "operation": "in_range",
            "right": [
                "XTVCUSDT"
            ]
        }
    ],
    "ignore_unknown_fields": false,
    "range": [
        0,
        1000
    ],
    "sort": {
        "sortBy": "24h_vol|5",
        "sortOrder": "desc"
    },
    "filter2": {
        "operator": "and",
        "operands": [
            {
                "expression": {
                    "left": "typespecs",
                    "operation": "has",
                    "right": [
                        "perpetual"
                    ]
                }
            },
            {
                "expression": {
                    "left": "centralization",
                    "operation": "equal",
                    "right": "cex"
                }
            }
        ]
    }
}